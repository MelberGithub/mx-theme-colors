#. TRANSLATORS App Name
#: ../mx-theme-colors:14
msgid "MX Theme Colors"
msgstr "MX Χρωματικά Θέματα"

#. TRANSLATORS warning message if themes are not installed line 1
#: ../mx-theme-colors:39
msgid "Themes not found!"
msgstr "Δεν βρέθηκαν θέματα!"

#. TRANSLATORS warning message if themes are not installed line 2
#: ../mx-theme-colors:41
msgid "This tool requires the MX-Matcha and MX-Ease themes to be installed."
msgstr "Αυτό το εργαλείο απαιτεί την εγκατάσταση θεμάτων MX-Matcha & MX-Ease"

#. TRANSLATORS Help window title
#: ../mx-theme-colors:69
msgid "MX Theme Colors Help"
msgstr "Βοήθεια MX Χρωματικών Θεμάτων "

#. TRANSLATORS Help window text line 0
#: ../mx-theme-colors:71
msgid "To create a new theme:"
msgstr "Για τη δημιουργία νέου θέματος:"

#. TRANSLATORS Help window text line 1
#: ../mx-theme-colors:73
msgid "Select theme to be edited from the drop-down list"
msgstr "Επιλέξτε θέμα για επεξεργασία από τη λίστα"

#. TRANSLATORS Help window text line 2
#: ../mx-theme-colors:75
msgid "Select new main color with the color palette or picker"
msgstr "Επιλέξτε νέο κύριο χρώμα με τη χρωματική παλέτα ή συλλέκτη"

#. TRANSLATORS Help window text line 3
#: ../mx-theme-colors:77
msgid "Select new secondary color with the color palette or picker"
msgstr "Επιλέξτε νέο δευτερεύον χρώμα με τη χρωματική παλέτα ή συλλέκτη"

#. TRANSLATORS Help window text line 4
#: ../mx-theme-colors:79
msgid "Update the preview image with the current selections"
msgstr "Ανανέωση της προεπισκόπησης με τις παρούσες επιλογές"

#. TRANSLATORS Help window text line 4a
#: ../mx-theme-colors:81
msgid "Repeat steps 1-4 until you are satisfied with the selections"
msgstr ""
"Επαναλάβετε τα βήματα 1-4 μέχρι να είστε ικανοποιημένοι με τις επιλογές"

#. TRANSLATORS Help window text line 5
#: ../mx-theme-colors:83
msgid "Enter name for new theme"
msgstr "Εισάγετε ονομασία για το νέο θέμα"

#. TRANSLATORS Help window text line 5a
#: ../mx-theme-colors:85
msgid "(name is appended to base theme name)"
msgstr "(ονομασία προστίθεται μετά το όνομα βασικού θέματος)"

#. TRANSLATORS Help window text line 7
#: ../mx-theme-colors:87
msgid "Confirm if hidpi and xhidpi versions should be created"
msgstr "Επιβεβαιώστε εαν hidpi και xhidpi εκδόσεις πρέπει να δημιουργηθούν"

#. TRANSLATORS Help window text line 6
#: ../mx-theme-colors:89
msgid "Click to create theme"
msgstr "Επιλέξτε για δημιουργία θέματος"

#. TRANSLATORS Help window text line 7
#: ../mx-theme-colors:91
msgid "Note: themes are saved in ~/.themes"
msgstr "Σημείωση: Τα θέματα αποθηκεύονται στον φάκελο ~/.themes"

#. TRANSLATORS Text in About window
#: ../mx-theme-colors:134
msgid "Edit the highlight colors of MX themes."
msgstr "Επεξεργασία των χρωμάτων τονισμού του MX Themes"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:203
msgid "Base Theme"
msgstr "Βασικό Θέμα"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:205
msgid "Main Color"
msgstr "Κύριο Χρώμα"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:207
msgid "Secondary Color"
msgstr "Δευτερεύον Χρώμα"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:209
msgid "Update Preview"
msgstr "Ανανέωση Προεπισκόπησης"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:211
msgid "Name for new theme"
msgstr "Ονομασία νέου θέματος"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:213
msgid "(name is appended to base theme)"
msgstr "(ονομασία προστίθεται μετά το βασικό θέμα)"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:215
msgid "Make new theme current"
msgstr "Μετατροπή νέου θέματος σε τρέχον"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:217
msgid "Create hidpi and xhidpi versions"
msgstr "Δημιουργιά hidpi και xhidpi εκδόσεων"

#. TRANSLATORS Button text
#: ../mx-theme-colors:221
msgid "Close"
msgstr "Κλείσιμο"

#. TRANSLATORS Button text
#: ../mx-theme-colors:223
msgid "Create Theme"
msgstr "Δημιουργία θέματος"

#. TRANSLATORS Button text
#: ../mx-theme-colors:225
msgid "Help"
msgstr "Βοήθεια"

#. TRANSLATORS Button text
#: ../mx-theme-colors:227
msgid "About"
msgstr "Περί"

#. TRANSLATORS Button text for color picker
#: ../mx-theme-colors:229
msgid "Custom Color Picker"
msgstr "Συλλέκτης ειδικού χρώματος"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:268
msgid "Preview"
msgstr "Προεπισκόπηση"

#. TRANSLATORS Main window text line 1
#: ../mx-theme-colors:277
msgid "Edit the highlight colors of the mx-matcha and mx-ease themes."
msgstr "Επεξεργασία των χρωμάτων τονισμού των θεμάτων  mx-matcha και mx-ease"

#. TRANSLATORS Main window text line 2
#: ../mx-theme-colors:279
msgid "Select base theme, main and secondary colors."
msgstr "Επιλογή βασικού θέματος, βασικών και δευτερευόντων χρωμάτων"

#. TRANSLATORS Main window text line 3
#: ../mx-theme-colors:281
msgid "Update preview, name and create new theme."
msgstr "Ανανέωση προεπισκόπησης, ονομασία και δημιουργία νέου θέματος."

#. TRANSLATORS Existing theme name window text line 1
#: ../mx-theme-colors:328
msgid "A theme with this name already exists."
msgstr "Θέμα με αυτή την ονομασία υπάρχει ήδη."

#. TRANSLATORS Existing theme name window text line 2
#: ../mx-theme-colors:330
msgid "Do you want to overwrite or save as a different theme name"
msgstr ""
"Θέλετε να αντικαταστήσετε το υπάρχον ή να το αποθηκεύσετε με άλλη ονομασία"

#. TRANSLATORS Existing theme name button
#: ../mx-theme-colors:332
msgid "Overwrite theme"
msgstr "Αντικατάσταση θέματος"

#. TRANSLATORS Existing theme name button
#: ../mx-theme-colors:334
msgid "Save as different name"
msgstr "Αποθήκευση με άλλη ονομασία"

#. TRANSLATORS Progress window text
#: ../mx-theme-colors:364 ../mx-theme-colors:624
msgid "Creating theme"
msgstr "Δημιουργία θέματος"

#. TRANSLATORS Task Completed window text 1
#: ../mx-theme-colors:634
msgid "All done!"
msgstr "Ολοκληρώθηκε!"

#. TRANSLATORS Task Completed window text 2, text is preceeded by theme name
#. and followed by path
#: ../mx-theme-colors:636
msgid "has been saved in"
msgstr "έχει αποθηκευτεί στο"

#. TRANSLATORS Task Completed window text 3
#: ../mx-theme-colors:640
msgid "Change themes with MX-Tweak"
msgstr "Αλλαγή θεμάτων με το MX-Tweak"

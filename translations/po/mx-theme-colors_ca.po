#. TRANSLATORS App Name
#: ../mx-theme-colors:14
msgid "MX Theme Colors"
msgstr "Colors del tema de l'MX"

#. TRANSLATORS warning message if themes are not installed line 1
#: ../mx-theme-colors:39
msgid "Themes not found!"
msgstr "No s'ha trobat cap tema!"

#. TRANSLATORS warning message if themes are not installed line 2
#: ../mx-theme-colors:41
msgid "This tool requires the MX-Matcha and MX-Ease themes to be installed."
msgstr ""
"Aquesta eina requereix que estiguin instal·lats els temes MX-Matcha i MX-"
"Ease."

#. TRANSLATORS Help window title
#: ../mx-theme-colors:69
msgid "MX Theme Colors Help"
msgstr "Ajuda dels colors del tema de l'MX"

#. TRANSLATORS Help window text line 0
#: ../mx-theme-colors:71
msgid "To create a new theme:"
msgstr "Per a crear un tema nou:"

#. TRANSLATORS Help window text line 1
#: ../mx-theme-colors:73
msgid "Select theme to be edited from the drop-down list"
msgstr "Seleccioneu el tema que voleu editar de la llista desplegable."

#. TRANSLATORS Help window text line 2
#: ../mx-theme-colors:75
msgid "Select new main color with the color palette or picker"
msgstr ""
"Seleccioneu el color principal nou amb la paleta de colors o el selector."

#. TRANSLATORS Help window text line 3
#: ../mx-theme-colors:77
msgid "Select new secondary color with the color palette or picker"
msgstr ""
"Seleccioneu el color secundari nou amb la paleta de colors o el selector."

#. TRANSLATORS Help window text line 4
#: ../mx-theme-colors:79
msgid "Update the preview image with the current selections"
msgstr "Actualitzeu la imatge de previsualització amb les seleccions actuals."

#. TRANSLATORS Help window text line 4a
#: ../mx-theme-colors:81
msgid "Repeat steps 1-4 until you are satisfied with the selections"
msgstr "Repetiu els passos 1-4 fins que estigueu satisfets de les seleccions."

#. TRANSLATORS Help window text line 5
#: ../mx-theme-colors:83
msgid "Enter name for new theme"
msgstr "Introduïu el nom del tema nou."

#. TRANSLATORS Help window text line 5a
#: ../mx-theme-colors:85
msgid "(name is appended to base theme name)"
msgstr "(El nom s'afegeix al nom del tema de base.)"

#. TRANSLATORS Help window text line 7
#: ../mx-theme-colors:87
msgid "Confirm if hidpi and xhidpi versions should be created"
msgstr "Confirmeu si se n'han de crear les versions hidpi i xhidpi."

#. TRANSLATORS Help window text line 6
#: ../mx-theme-colors:89
msgid "Click to create theme"
msgstr "Cliqueu per crear el tema"

#. TRANSLATORS Help window text line 7
#: ../mx-theme-colors:91
msgid "Note: themes are saved in ~/.themes"
msgstr "Nota: els temes es desen a ~/.themes."

#. TRANSLATORS Text in About window
#: ../mx-theme-colors:134
msgid "Edit the highlight colors of MX themes."
msgstr "Editeu els colors de ressaltat dels temes de l'MX."

#. TRANSLATORS Main window label
#: ../mx-theme-colors:203
msgid "Base Theme"
msgstr "Tema de base"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:205
msgid "Main Color"
msgstr "Color principal"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:207
msgid "Secondary Color"
msgstr "Color secundari"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:209
msgid "Update Preview"
msgstr "Actualitza la vista prèvia"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:211
msgid "Name for new theme"
msgstr "Nom del tema nou"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:213
msgid "(name is appended to base theme)"
msgstr "(El nom s'afegeix al tema de base.)"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:215
msgid "Make new theme current"
msgstr "Fes actual el tema nou"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:217
msgid "Create hidpi and xhidpi versions"
msgstr "Crea'n versions hidpi i xhidpi"

#. TRANSLATORS Button text
#: ../mx-theme-colors:221
msgid "Close"
msgstr "Tanca"

#. TRANSLATORS Button text
#: ../mx-theme-colors:223
msgid "Create Theme"
msgstr "Crea un Tema"

#. TRANSLATORS Button text
#: ../mx-theme-colors:225
msgid "Help"
msgstr "Ajuda"

#. TRANSLATORS Button text
#: ../mx-theme-colors:227
msgid "About"
msgstr "Quant a "

#. TRANSLATORS Button text for color picker
#: ../mx-theme-colors:229
msgid "Custom Color Picker"
msgstr "Selector de colors personalitzats"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:268
msgid "Preview"
msgstr "Vista prèvia"

#. TRANSLATORS Main window text line 1
#: ../mx-theme-colors:277
msgid "Edit the highlight colors of the mx-matcha and mx-ease themes."
msgstr "Editeu els colors de ressaltat dels temes mx-matcha i mx-ease."

#. TRANSLATORS Main window text line 2
#: ../mx-theme-colors:279
msgid "Select base theme, main and secondary colors."
msgstr "Seleccioneu el tema de base, els colors principals i els secundaris."

#. TRANSLATORS Main window text line 3
#: ../mx-theme-colors:281
msgid "Update preview, name and create new theme."
msgstr "Actualitzeu-ne la vista prèvia, poseu-hi nom i creeu un tema nou."

#. TRANSLATORS Existing theme name window text line 1
#: ../mx-theme-colors:328
msgid "A theme with this name already exists."
msgstr "Ja existeix un tema amb aquest nom."

#. TRANSLATORS Existing theme name window text line 2
#: ../mx-theme-colors:330
msgid "Do you want to overwrite or save as a different theme name"
msgstr "Voleu sobreescriure'l o desar-lo amb un nom de tema diferent?"

#. TRANSLATORS Existing theme name button
#: ../mx-theme-colors:332
msgid "Overwrite theme"
msgstr "Sobreescriu el tema"

#. TRANSLATORS Existing theme name button
#: ../mx-theme-colors:334
msgid "Save as different name"
msgstr "Desa amb un nom diferent"

#. TRANSLATORS Progress window text
#: ../mx-theme-colors:364 ../mx-theme-colors:624
msgid "Creating theme"
msgstr "Creació del tema"

#. TRANSLATORS Task Completed window text 1
#: ../mx-theme-colors:634
msgid "All done!"
msgstr "Ja està fet!"

#. TRANSLATORS Task Completed window text 2, text is preceeded by theme name
#. and followed by path
#: ../mx-theme-colors:636
msgid "has been saved in"
msgstr "s'ha desat a"

#. TRANSLATORS Task Completed window text 3
#: ../mx-theme-colors:640
msgid "Change themes with MX-Tweak"
msgstr "Canvieu els temes amb l'MX-Tweak."

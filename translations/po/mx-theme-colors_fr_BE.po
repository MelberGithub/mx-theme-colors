#. TRANSLATORS App Name
#: ../mx-theme-colors:14
msgid "MX Theme Colors"
msgstr "MX Couleurs de thème - MX Theme Colors"

#. TRANSLATORS warning message if themes are not installed line 1
#: ../mx-theme-colors:39
msgid "Themes not found!"
msgstr "Aucun thème trouvé!"

#. TRANSLATORS warning message if themes are not installed line 2
#: ../mx-theme-colors:41
msgid "This tool requires the MX-Matcha and MX-Ease themes to be installed."
msgstr "Cet outil nécessite l’installation des thèmes MX‑Matcha et MX‑Ease."

#. TRANSLATORS Help window title
#: ../mx-theme-colors:69
msgid "MX Theme Colors Help"
msgstr "Aide de l’outil « MX Couleurs de thème »"

#. TRANSLATORS Help window text line 0
#: ../mx-theme-colors:71
msgid "To create a new theme:"
msgstr "Pour créer un nouveau thème:"

#. TRANSLATORS Help window text line 1
#: ../mx-theme-colors:73
msgid "Select theme to be edited from the drop-down list"
msgstr "Sélectionnez le thème à modifier dans la liste déroulante"

#. TRANSLATORS Help window text line 2
#: ../mx-theme-colors:75
msgid "Select new main color with the color palette or picker"
msgstr ""
"Sélectionnez la nouvelle couleur principale à l’aide de la palette ou du "
"sélecteur de couleurs"

#. TRANSLATORS Help window text line 3
#: ../mx-theme-colors:77
msgid "Select new secondary color with the color palette or picker"
msgstr ""
"Sélectionnez la nouvelle couleur secondaire à l’aide de la palette ou du "
"sélecteur de couleurs"

#. TRANSLATORS Help window text line 4
#: ../mx-theme-colors:79
msgid "Update the preview image with the current selections"
msgstr "Mettez à jour l’image d’aperçu avec les sélections actuelles"

#. TRANSLATORS Help window text line 4a
#: ../mx-theme-colors:81
msgid "Repeat steps 1-4 until you are satisfied with the selections"
msgstr "Répétez les étapes 1 à 4 jusqu’à être satisfait des sélections"

#. TRANSLATORS Help window text line 5
#: ../mx-theme-colors:83
msgid "Enter name for new theme"
msgstr "Saisissez un nom pour le nouveau thème"

#. TRANSLATORS Help window text line 5a
#: ../mx-theme-colors:85
msgid "(name is appended to base theme name)"
msgstr "(le nom est ajouté au nom de base du thème)"

#. TRANSLATORS Help window text line 7
#: ../mx-theme-colors:87
msgid "Confirm if hidpi and xhidpi versions should be created"
msgstr "Confirmez si des versions hidpi et xhidpi doivent être créées"

#. TRANSLATORS Help window text line 6
#: ../mx-theme-colors:89
msgid "Click to create theme"
msgstr "Cliquez pour créer le thème"

#. TRANSLATORS Help window text line 7
#: ../mx-theme-colors:91
msgid "Note: themes are saved in ~/.themes"
msgstr "Note: les thèmes sont enregistrés dans ~/.themes"

#. TRANSLATORS Text in About window
#: ../mx-theme-colors:134
msgid "Edit the highlight colors of MX themes."
msgstr "Modifier les couleurs de surbrillance des thèmes MX."

#. TRANSLATORS Main window label
#: ../mx-theme-colors:203
msgid "Base Theme"
msgstr "Thème de base"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:205
msgid "Main Color"
msgstr "Couleur principale"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:207
msgid "Secondary Color"
msgstr "Couleur secondaire"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:209
msgid "Update Preview"
msgstr "Mettre à jour l’aperçu"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:211
msgid "Name for new theme"
msgstr "Nom du nouveau thème"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:213
msgid "(name is appended to base theme)"
msgstr "(le nom est ajouté au thème de base)"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:215
msgid "Make new theme current"
msgstr "Définir le nouveau thème comme thème actuel"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:217
msgid "Create hidpi and xhidpi versions"
msgstr "Créer des versions hidpi et xhidpi"

#. TRANSLATORS Button text
#: ../mx-theme-colors:221
msgid "Close"
msgstr "Quitter"

#. TRANSLATORS Button text
#: ../mx-theme-colors:223
msgid "Create Theme"
msgstr "Créer un thème"

#. TRANSLATORS Button text
#: ../mx-theme-colors:225
msgid "Help"
msgstr "Aide"

#. TRANSLATORS Button text
#: ../mx-theme-colors:227
msgid "About"
msgstr "À propos"

#. TRANSLATORS Button text for color picker
#: ../mx-theme-colors:229
msgid "Custom Color Picker"
msgstr "Sélecteur de couleur personnalisé"

#. TRANSLATORS Main window label
#: ../mx-theme-colors:268
msgid "Preview"
msgstr "Aperçu"

#. TRANSLATORS Main window text line 1
#: ../mx-theme-colors:277
msgid "Edit the highlight colors of the mx-matcha and mx-ease themes."
msgstr ""
"Modifier les couleurs de surbrillance des thèmes mx-matcha et mx-ease."

#. TRANSLATORS Main window text line 2
#: ../mx-theme-colors:279
msgid "Select base theme, main and secondary colors."
msgstr ""
"Sélectionner le thème de base ainsi que les couleurs principale et "
"secondaire."

#. TRANSLATORS Main window text line 3
#: ../mx-theme-colors:281
msgid "Update preview, name and create new theme."
msgstr "Mettre à jour l’aperçu, nommer et créer le nouveau thème."

#. TRANSLATORS Existing theme name window text line 1
#: ../mx-theme-colors:328
msgid "A theme with this name already exists."
msgstr "Un thème portant ce nom existe déjà."

#. TRANSLATORS Existing theme name window text line 2
#: ../mx-theme-colors:330
msgid "Do you want to overwrite or save as a different theme name"
msgstr "Voulez-vous l’écraser ou l’enregistrer sous un autre nom?"

#. TRANSLATORS Existing theme name button
#: ../mx-theme-colors:332
msgid "Overwrite theme"
msgstr "Écraser le thème"

#. TRANSLATORS Existing theme name button
#: ../mx-theme-colors:334
msgid "Save as different name"
msgstr "Enregistrer sous un autre nom"

#. TRANSLATORS Progress window text
#: ../mx-theme-colors:364 ../mx-theme-colors:624
msgid "Creating theme"
msgstr "Création du thème"

#. TRANSLATORS Task Completed window text 1
#: ../mx-theme-colors:634
msgid "All done!"
msgstr "Terminé!"

#. TRANSLATORS Task Completed window text 2, text is preceeded by theme name
#. and followed by path
#: ../mx-theme-colors:636
msgid "has been saved in"
msgstr "a été enregistré dans"

#. TRANSLATORS Task Completed window text 3
#: ../mx-theme-colors:640
msgid "Change themes with MX-Tweak"
msgstr "Changer de thème avec MX Ajustements ‑ MX Tweak"
